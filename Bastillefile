ARG REDIS_VERSION=74
ARG REDIS_PORT=6379
ARG REDIS_MAXMEM=512mb
ARG REDIS_MAXPOL=allkeys-lru
ARG REDIS_REQUIREPASS=changeme!

# install required templates
INCLUDE https://github.com/bastille-templates/openssl

# install required packages
PKG redis${REDIS_VERSION} 

# copy files
CP usr /

RENDER /usr/local/etc/redis.conf

# enable and start redis
SYSRC redis_enable=YES

SERVICE redis start

#RDR tcp ${REDIS_PORT} 6379

TAGS database redis${REDIS_VERSION}
